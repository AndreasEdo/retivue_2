# Salin file ini jadi `.env` (di folder backend/) lalu isi nilainya.
# JANGAN commit .env — sudah di-gitignore.

# --- MongoDB Atlas ---
# Ambil dari Atlas: Database > Connect > Drivers > Python. Ganti <password> & <dbname>.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=retivue

# --- JWT ---
# Ganti dengan string acak panjang (mis. hasil: openssl rand -hex 32)
JWT_SECRET=ganti-dengan-string-acak-panjang
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Seed akun demo ---
SEED_DEMO=true
SEED_PASSWORD=Retivue123!

# --- Cloudinary (penyimpanan gambar) ---
# Dari dashboard Cloudinary: Account Details.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- AI ---
ENSEMBLE=false

# --- CORS (URL frontend; * untuk dev) ---
CORS_ORIGINS=*
